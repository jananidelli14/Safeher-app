# ─────────────────────────────────────────────────────────────────
#  SafeHer Backend — Environment Variables
#  Copy this file to backend/.env and fill in your actual values
#  NEVER commit the filled .env to Git!
# ─────────────────────────────────────────────────────────────────

# ── Flask Security ─────────────────────────────────────────────────
SECRET_KEY=change-this-to-a-long-random-string-in-production
JWT_SECRET_KEY=change-this-jwt-secret-to-something-long-and-random
JWT_ACCESS_TOKEN_EXPIRES_DAYS=7

# ── Database (Supabase PostgreSQL) ─────────────────────────────────
DATABASE_URL=postgresql://postgres:[PASSWORD]@db.[PROJECT_REF].supabase.co:5432/postgres
SUPABASE_URL=https://[PROJECT_REF].supabase.co
SUPABASE_ANON_KEY=your_supabase_anon_key_here

# ── Google Gemini AI (for chatbot) ─────────────────────────────────
# Get from: https://aistudio.google.com/app/apikey
# Click "Create API Key" → copy the key below
GEMINI_API_KEY=your_gemini_api_key_here

# ── Twilio (for SOS SMS) ───────────────────────────────────────────
# Get from: https://console.twilio.com (see SETUP GUIDE below)
TWILIO_ACCOUNT_SID=ACxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
TWILIO_AUTH_TOKEN=your_twilio_auth_token_here
TWILIO_PHONE_NUMBER=+1XXXXXXXXXX

# ── SendGrid (for SOS Email) ───────────────────────────────────────
# Get from: https://sendgrid.com → API Keys
SENDGRID_API_KEY=SG.xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
FROM_EMAIL=noreply@safehertravel.com

# ── Google Places API (for map features) ──────────────────────────
# Get from: https://console.cloud.google.com → APIs & Services
GOOGLE_PLACES_API_KEY=your_google_places_api_key_here

# ─────────────────────────────────────────────────────────────────
# TWILIO SETUP GUIDE — Step by Step
# ─────────────────────────────────────────────────────────────────
#
# STEP 1: Create Twilio Account
#   → Go to https://www.twilio.com/try-twilio
#   → Sign up with your email (free trial gives ~$15 credit)
#   → Verify your phone number
#
# STEP 2: Get Account SID and Auth Token
#   → Go to https://console.twilio.com
#   → On the dashboard, you'll see "Account SID" and "Auth Token"
#   → Copy both values to TWILIO_ACCOUNT_SID and TWILIO_AUTH_TOKEN above
#
# STEP 3: Get a Twilio Phone Number (for SMS sending)
#   → In Twilio Console → Phone Numbers → Buy a Number
#   → Filter by: Country = India (if available) OR United States
#   → Select a number with SMS capabilities
#   → Click "Buy" (uses your trial credit)
#   → Copy the number (e.g. +14155552671) to TWILIO_PHONE_NUMBER above
#
# STEP 4: For India SMS (Important!)
#   → India requires DLT (Distributed Ledger Technology) registration
#   → For production: register at https://www.trai.gov.in/dlt
#   → For testing: use the Twilio trial to send to VERIFIED numbers only
#   → To verify a number in trial: Console → Phone Numbers → Verified Caller IDs
#
# STEP 5: Test SMS
#   → Run: python backend/test_connection.py
#   → Or trigger an SOS in the app and check logs
#
# STEP 6: Move to Production
#   → Upgrade Twilio account (remove trial restrictions)
#   → Complete DLT registration for India bulk SMS
#   → Use an Indian virtual number for better delivery rates
#
# ─────────────────────────────────────────────────────────────────
# GEMINI API SETUP GUIDE
# ─────────────────────────────────────────────────────────────────
#
# STEP 1: Go to https://aistudio.google.com/app/apikey
# STEP 2: Sign in with your Google account
# STEP 3: Click "Create API Key"
# STEP 4: Select your Google Cloud project (or create a new one)
# STEP 5: Copy the generated API key
# STEP 6: Paste it as GEMINI_API_KEY above
#
# Free tier: 15 requests/minute, 1 million tokens/day
# For production: Enable billing at https://console.cloud.google.com
# ─────────────────────────────────────────────────────────────────
